{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": [
    {
      "name": "web",
      "command": "gunicorn app:app",
      "port": 8080
    },
    {
      "name": "worker",
      "command": "python bot.py"
    }
  ]
}
